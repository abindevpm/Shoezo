<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHOEZO - Comfort & Style</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f7f7f7;
        }
        /* Custom gradient for buttons/CTA, now using dark charcoal/black */
        .cta-button {
            background-image: linear-gradient(to right, #1f2937, #111827); /* Dark Gray to Black */
            transition: all 0.3s ease;
        }
        .cta-button:hover {
            opacity: 0.9;
            transform: scale(1.02);
        }
        /* Custom styling for the feature bar icons (larger, prominent black) */
        .feature-icon-group {
            display: flex;
            align-items: center;
        }
        .feature-icon-svg {
            color: #111827; /* Dark Black Color */
            width: 32px; /* Large icon size */
            height: 32px;
            margin-right: 12px; /* Equivalent to mr-3 */
        }
        .feature-title {
            font-size: 1rem; /* Equivalent to text-base */
            font-weight: 600; /* Equivalent to font-semibold */
            color: #111827; /* Gray-900 */
            line-height: 1.25;
        }
        .feature-subtitle {
            font-size: 0.875rem; /* Equivalent to text-sm */
            color: #000000; /* Gray-600 */
        }
    </style>
</head>
<body>
    
    <% 
        // --- Simulated Server-side Data / EJS Logic ---

        // IMPORTANT: TO CHANGE PRODUCT IMAGES, UPDATE THE 'image' URL IN THIS ARRAY.
        const products = [
            { id: 1, name: "Nike Air Max", price: 109.99, rating: 4.5, reviews: 250, discount: 30, color: 'white', text: 'NIKE AIR', image: 'https://placehold.co/400x300/111827/fff?text=NIKE+AIR+MAX' },
            { id: 2, name: "Nike Kybrid S2", price: 179.99, rating: 4.2, reviews: 180, discount: 20, color: 'white', text: 'NIKE KYBRID', image: 'https://placehold.co/400x300/111827/fff?text=NIKE+KYBRID+S2' },
            { id: 3, name: "Adidas Orange", price: 129.99, rating: 4.5, reviews: 200, discount: 30, color: 'orange', text: 'ADIDAS ORANGE', image: 'https://placehold.co/400x300/f97316/fff?text=ADIDAS+ORANGE' },
            { id: 4, name: "Cinderella Red", price: 89.99, rating: 4.9, reviews: 300, discount: 30, color: 'red', text: 'RED HEEL', image: 'https://placehold.co/400x300/ef4444/fff?text=RED+HEEL' },
            { id: 5, name: "Nike Krypton", price: 159.99, rating: 4.0, reviews: 150, discount: 30, color: 'gold', text: 'NIKE KRYPTO', image: 'https://placehold.co/400x300/a35400/fff?text=NIKE+KRYPTO' },
            { id: 6, name: "Puma Retro", price: 99.99, rating: 4.8, reviews: 220, discount: 30, color: 'mint', text: 'PUMA RETRO', image: 'https://placehold.co/400x300/0d9488/fff?text=PUMA+RETRO' },
        ];

        // Function to generate Star icons (SVG) using EJS logic
        const generateStars = (rating) => {
            const fullStars = Math.floor(rating);
            let starsHtml = '';
            for (let i = 0; i < 5; i++) {
                if (i < fullStars) {
                    // Full Star
                    starsHtml += `<svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>`;
                } else {
                    // Empty Star
                    starsHtml += `<svg class="w-4 h-4 text-gray-300 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>`;
                }
            }
            return starsHtml;
        };
    %>

    <header class="bg-white sticky top-0 z-50 shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center">
            
            <a href="#" class="flex items-center space-x-2 text-3xl font-extrabold tracking-widest text-black mb-4 md:mb-0">
                <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 18H4a2 2 0 01-2-2v-4a2 2 0 012-2h12a3 3 0 013 3v1a3 3 0 01-3 3H10z"/>
                    <path d="M6 14h4M6 16h4"/>
                    <path d="M22 12h-4M22 8h-3M22 16h-3"/>
                </svg>
                <span class="text-black">SHOEZO</span>
            </a>
            
            <nav class="flex space-x-6 text-gray-600 font-medium md:absolute md:left-1/2 md:-translate-x-1/2 md:flex-row">
                <a href="#" class="hover:text-black transition duration-150">Home</a>
                <a href="#" class="hover:text-black transition duration-150">Shop</a>
                <a href="#" class="hover:text-black transition duration-150">Orders</a>
            </nav>

            <div class="flex items-center space-x-4 mt-4 md:mt-0">
                <div class="relative hidden lg:block">
                    <input type="text" placeholder="Search" class="border border-gray-300 rounded-full py-2 pl-4 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-gray-700 transition duration-150 w-64">
                    <button class="absolute right-0 top-0 mt-2 mr-3 text-gray-500 hover:text-black">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </button>
                </div>
                <!-- RIGHT SIDE (LOGIN + SIGNUP) -->
                  <div class="hidden md:flex items-center space-x-6">

             <!-- LOGIN -->
             <a href="/login" class="text-gray-700 font-medium hover:text-blue-600 transition">
              Login
               </a>

  <!-- SIGNUP -->
  <a href="/signup" class="text-gray-700 font-medium hover:text-blue-600 transition">
    Signup
  </a>

</div>



             
            </div>
        </div>
    </header>

    <main class="max-w-8xl mx-auto">

        <section class="relative h-[650px] overflow-hidden rounded-b-lg mb-12">
            
            <img src="/images/ADIDAS.jpg" 
                alt="Fashion Background" 
                class="absolute inset-0 w-full h-full object-cover" 
                onerror="this.src='https://placehold.co/1200x650/111827/fff?text=HIGH+FASHION+BACKGROUND+IMAGE+GOES+HERE'">
            
            <div class="relative z-10 h-full flex items-start p-10 md:p-20">
                <div class="max-w-md">
                    <p class="text-xl font-medium text-gray-200 mb-2 tracking-widest">FOCUS ON COMFORT & STYLE</p>
                    <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 leading-tight">
                        Your Next Level Footwear
                    </h1>
                    <p class="text-gray-300 mb-8">
                        Experience the perfect blend of innovation, quality, and trend-setting design. Step into the future of fashion.
                    </p>
                    <a href="#" class="cta-button inline-block text-white font-bold py-3 px-8 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 text-lg uppercase tracking-wider">
                        Shop Collection
                    </a>
                </div>
            </div>
        </section>

        <section class="flex justify-center -mt-8 mb-20 space-x-4 md:space-x-12 z-20 relative">
            
            <a href="#" class="flex flex-col items-center group">
                <div class="w-24 h-24 md:w-32 md:h-32 bg-white rounded-full p-2 shadow-lg ring-4 ring-gray-200 group-hover:ring-black transition-all duration-300">
                    <img src="/images/shoe.avif" alt="Men's Shoes" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="mt-3 text-sm md:text-base font-semibold text-gray-700 group-hover:text-black transition">MEN'S</span>
            </a>
            
            <a href="#" class="flex flex-col items-center group">
                <div class="w-24 h-24 md:w-32 md:h-32 bg-white rounded-full p-2 shadow-lg ring-4 ring-gray-200 group-hover:ring-black transition-all duration-300">
                    <img src="/images/kiddd.jpg" alt="Kids Shoes" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="mt-3 text-sm md:text-base font-semibold text-gray-700 group-hover:text-black transition">KIDS</span>
            </a>
            
            <a href="#" class="flex flex-col items-center group">
                <div class="w-24 h-24 md:w-32 md:h-32 bg-white rounded-full p-2 shadow-lg ring-4 ring-gray-200 group-hover:ring-black transition-all duration-300">
                    <img src="/images/cindrella.jpg" alt="Women's Shoes" class="w-full h-full object-cover rounded-full">
                </div>
                <span class="mt-3 text-sm md:text-base font-semibold text-gray-700 group-hover:text-black transition">WOMEN'S</span>
            </a>
        </section>

        <section class="h-[700px] overflow-hidden rounded-lg mb-12 relative">
            
            <img src="/images/pexels-jddaniel-2385477.jpg" 
                alt="Jordan Mid-Season Drop" 
                class="w-full h-full object-cover absolute inset-0" 
                onerror="this.src='https://placehold.co/1200x600/fbb03b/333?text=JORDAN+MID-SEASON+DROP+-+PLACE+YOUR+IMAGE+HERE'">
            
            <div class="relative z-10 w-full h-full flex flex-col items-center justify-center text-center p-8">
                <div class="max-w-xl">
                    <h3 class="text-5xl font-extrabold text-white mb-2">LIMITED TIME COLLECTION</h3>
                    <p class="text-xl text-white">Find exclusive colorways and performance gear.</p>
                </div>
            </div>
        </section>

        <h2 class="text-3xl font-bold text-gray-800 mb-6 px-4 sm:px-0">Featured Products</h2>

        <section id="product-grid-container" class="grid grid-cols-2 md:grid-cols-3 gap-6 px-4 sm:px-0 mb-12">
            
            <% products.forEach(product => { %>
                <div class="bg-white p-4 rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 transform hover:scale-[1.01] flex flex-col justify-between">
                    <div class="relative">
                        <img src="/images/nike rt.avif" 
                            alt="<%= product.name %>" 
                            class="w-full h-auto object-cover rounded-lg mb-4 aspect-[4/3]"
                            onerror="this.onerror=null; this.src='<%= product.image %>';">
                        
                        <button class="absolute top-2 right-2 p-2 bg-white/70 backdrop-blur-sm rounded-full shadow-lg hover:bg-red-100 transition duration-150">
                            <svg class="w-5 h-5 text-gray-400 hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                        </button>
                    </div>

                    <div class="flex flex-col">
                        <h3 class="font-semibold text-lg mb-1 truncate"><%= product.name %></h3>
                        
                        <div class="flex justify-between items-center mb-2">
                            <p class="text-xl font-bold text-gray-800">
                                $<%= product.price.toFixed(2) %>
                            </p>
                            <div class="flex items-center text-sm text-gray-500">
                                <span class="flex mr-1"><%- generateStars(product.rating) %></span>
                                (<%= product.reviews %>)
                            </div>
                        </div>

                        <div class="flex justify-between items-center">
                            <p class="text-sm font-medium text-red-500"><%= product.discount %>% OFF</p>
                            <button class="flex items-center text-sm font-medium text-gray-900 hover:text-gray-700 transition duration-150">
                                Buy Now
                                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                        </div>
                    </div>
                </div>
            <% }); %>

        </section>






        
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6 border-y border-gray-300 py-10 px-4 sm:px-0 mb-12">
            
            <div class="feature-icon-group justify-start">
                <svg class="feature-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                <div>
                    <h4 class="feature-title">FREE SHIPPING</h4>
                    <p class="feature-subtitle">Orders over $50</p>
                </div>
            </div>
            
            <div class="feature-icon-group justify-start">
                <svg class="feature-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                <div>
                    <h4 class="feature-title">EASY RETURNS</h4>
                    <p class="feature-subtitle">30 days exchange</p>
                </div>
            </div>

            <div class="feature-icon-group justify-start">
                <svg class="feature-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2l-2 2v-4h3.586a1 1 0 01.707.293L13 15h5a2 2 0 002-2V9a2 2 0 00-2-2h-3"></path></svg>
                <div>
                    <h4 class="feature-title">24/7 SUPPORT</h4>
                    <p class="feature-subtitle">Dedicated customer service</p>
                </div>
            </div>

        </section>

    </main>

    <footer class="bg-gray-900 text-white pt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 pb-12">
                
                <div class="md:col-span-1">
                    <a href="#" class="text-4xl font-extrabold tracking-widest text-white mb-4 block [text-shadow:0_0_8px_rgba(255,255,255,0.2)]">
                        SHOEZO
                    </a>
                    <p class="text-gray-400 text-sm">
                        The ultimate destination for the latest in footwear fashion.
                    </p>
                </div>

                <div class="md:col-span-1">
                    <h5 class="font-semibold text-xl mb-6 uppercase tracking-wider">My Account</h5>
                    <ul class="space-y-3 text-gray-400">
                        <li><a href="#" class="hover:text-white transition text-sm">My Orders</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">View Cart</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Wishlist</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Track Order</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Help</a></li>
                    </ul>
                </div>

                <div class="md:col-span-1">
                    <h5 class="font-semibold text-xl mb-6 uppercase tracking-wider">Information</h5>
                    <ul class="space-y-3 text-gray-400">
                        <li><a href="#" class="hover:text-white transition text-sm">About Us</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Privacy Policy</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Terms & Conditions</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">Delivery Information</a></li>
                        <li><a href="#" class="hover:text-white transition text-sm">FAQ</a></li>
                    </ul>
                </div>
                
                <div class="md:col-span-1">
                    <h5 class="font-semibold text-xl mb-6 uppercase tracking-wider">Contact Us</h5>
                    <div class="space-y-4 text-gray-400">
                        <div class="flex items-start">
                            <svg class="w-6 h-6 text-gray-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.828 0l-4.243-4.243m10.606 0a2 2 0 11-2.828-2.828 2 2 0 012.828 2.828z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 13V7"></path></svg>
                            <span class="text-sm">123 Shoe Street, Footwear City, CA 90210</span>
                        </div>
                        <div class="flex items-center">
                            <svg class="w-6 h-6 text-gray-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span class="text-sm">(555) 123-SHOE</span>
                        </div>
                        <div class="flex items-center">
                            <svg class="w-6 h-6 text-gray-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-17 4v6a2 2 0 002 2h14a2 2 0 002-2v-6"></path></svg>
                            <span class="text-sm">support@shoezo.com</span>
                        </div>
                    </div>
                    <div class="flex space-x-4 mt-8">
                        <a href="#" class="text-gray-400 hover:text-white transition"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14 13.5h2.5L17 10h-3v-2c0-1.5 0-2 2-2h1.5V2.14a22.353 22.353 0 00-3.32-.23c-3.23 0-5.5 1.55-5.5 5.5v3.5H7v3.5h3v8.5h4v-8.5z"/></svg>
                        </a>
                        <a href="#" class="text-gray-400 hover:text-white transition"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.5 4.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm-7 11a7 7 0 110-14 7 7 0 010 14zM12 16a4 4 0 100-8 4 4 0 000 8zm-4.5-4.5a.5.5 0 100 1 .5.5 0 000-1z"/></svg>
                        </a>
                        <a href="#" class="text-gray-400 hover:text-white transition"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 6.923a8.384 8.384 0 01-2.404.664 4.17 4.17 0 001.815-2.316 8.381 8.381 0 01-2.65 1.015 4.17 4.17 0 00-7.086 3.814 11.854 11.854 0 01-8.6-4.352 4.17 4.17 0 001.289 5.56 4.168 4.168 0 01-1.884-.519v.053a4.17 4.17 0 003.342 4.095 4.195 4.195 0 01-1.883.072 4.17 4.17 0 003.882 2.895 8.38 8.38 0 01-5.186 1.782 11.8 11.8 0 006.417 1.873c7.69 0 11.903-6.4 11.903-11.903v-.543a8.514 8.514 0 002.083-2.164z"/></svg>
                        </a>
                    </div>
                </div>

            </div>
            
            <div class="border-t border-gray-700 py-6">
                <p class="text-center text-gray-500 text-sm">
                    &copy; 2024 SHOEZO. All rights reserved. Designed with style and comfort.
                </p>
            </div>
        </div>
    </footer>
</body>
</html>



