<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Failed</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        .payment-wrapper {
            min-height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 0;
        }

        .order-label {
            color: #888;
            font-size: 0.95rem;
        }

        .order-value {
            font-weight: 700;
            text-align: right;
            color: #333;
        }

        .status-text {
            font-weight: 900;
            font-size: 1.8rem;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-retry {
            background-color: #ff6b6b;
            color: white;
            border: none;
            padding: 12px 35px;
            border-radius: 30px;
            font-weight: bold;
            transition: 0.3s;
            text-transform: uppercase;
        }

        .btn-retry:hover {
            background-color: #ee5253;
            color: white;
            transform: translateY(-2px);
        }

        .dotted-line {
            border-top: 2px dotted #eee;
            margin: 15px 0;
        }

        .error-icon-wrapper {
            width: 100px;
            height: 100px;
            background-color: #fff1f1;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 4px solid #ff6b6b;
        }

        .error-icon-wrapper i {
            font-size: 50px;
            color: #ff6b6b;
        }

        .detail-card {
            background: #fff;
            border: 1px solid #eee;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: left;
        }

        .detail-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: #222;
            border-bottom: 1px solid #f9f9f9;
            padding-bottom: 8px;
        }

        .item-row {
            display: flex;
            gap: 15px;
            padding: 10px 0;
            border-bottom: 1px solid #f5f5f5;
        }

        .item-row:last-child {
            border-bottom: none;
        }

        .item-img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
        }

        .item-info p {
            margin: 0;
            font-size: 0.9rem;
        }

        .address-box p {
            margin-bottom: 5px;
            font-size: 0.95rem;
            color: #555;
        }
    </style>
</head>

<body>

    <%- include('../partials/userpartial/header.ejs') %>

        <% const safeOrder=typeof order !=="undefined" ? order : null; %>

            <main class="payment-wrapper">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-12 col-md-6 col-lg-4 text-center">

                            <div class="error-icon-wrapper mb-4">
                                <i class="fas fa-times"></i>
                            </div>

                            <% if (safeOrder) { %>

                                <div class="px-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="order-label">Shoezo Order ID</span>
                                        <span class="order-value text-break" style="max-width: 200px;">
                                            <%= safeOrder.orderId %>
                                        </span>
                                    </div>

                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="order-label">Date</span>
                                        <span class="order-value">
                                            <%= new Date(safeOrder.createdAt).toDateString() %>
                                        </span>
                                    </div>

                                    <div class="d-flex justify-content-between mb-4">
                                        <span class="order-label">Total Amount</span>
                                        <span class="order-value" style="color: #ff6b6b; font-size: 1.1rem;">
                                            ₹ <%= safeOrder.totalAmount.toLocaleString() %>
                                        </span>
                                    </div>

                                    <!-- Shipping Address Section -->
                                    <div class="detail-card">
                                        <h4 class="detail-title">Shipping Address</h4>
                                        <div class="address-box">
                                            <p><strong>
                                                    <%= safeOrder.address.fullName %>
                                                </strong></p>
                                            <p>
                                                <%= safeOrder.address.addressLine %>
                                            </p>
                                            <p>
                                                <%= safeOrder.address.city %>, <%= safeOrder.address.state %> - <%=
                                                            safeOrder.address.pincode %>
                                            </p>
                                            <p><i class="fas fa-phone-alt me-2"></i>+91 <%= safeOrder.address.phone %>
                                            </p>
                                        </div>
                                    </div>

                                    <!-- Order Items Section -->
                                    <div class="detail-card">
                                        <h4 class="detail-title">Items in Order</h4>
                                        <% safeOrder.items.forEach(item=> { %>
                                            <div class="item-row">
                                                <% if (item.productId) { %>
                                                    <img src="/uploads/product-images/<%= item.productId.images[0] %>"
                                                        alt="<%= item.productId.name %>" class="item-img">
                                                    <div class="item-info">
                                                        <p><strong>
                                                                <%= item.productId.name %>
                                                            </strong></p>
                                                        <p class="text-muted">Size: <%= item.size %> | Qty: <%=
                                                                    item.quantity %>
                                                        </p>
                                                        <p>₹<%= item.price.toLocaleString() %>
                                                        </p>
                                                    </div>
                                                    <% } else { %>
                                                        <div class="item-info">
                                                            <p><strong>Product Unavailable</strong></p>
                                                            <p class="text-muted">Size: <%= item.size %> | Qty: <%=
                                                                        item.quantity %>
                                                            </p>
                                                            <p>₹<%= item.price.toLocaleString() %>
                                                            </p>
                                                        </div>
                                                        <% } %>
                                            </div>
                                            <% }) %>
                                    </div>
                                </div>

                                <% } else { %>

                                    <p class="text-muted mb-4">
                                        No order details available.
                                    </p>

                                    <% } %>

                                        <h2 class="status-text mb-4 text-danger">
                                            PAYMENT FAILED
                                            <i class="fas fa-times-circle"></i>
                                        </h2>

                                        <a href="/checkout" class="btn btn-retry shadow-sm">
                                            RETRY PAYMENT
                                        </a>

                                        <div class="mt-3">
                                            <a href="/orders" class="btn btn-outline-secondary">
                                                View Order Details
                                            </a>
                                        </div>

                        </div>
                    </div>
                </div>
            </main>

            <%- include('../partials/userpartial/footer.ejs') %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>