<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Complete Signup - Shoezo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f8f9fa;
    }

    .referral-card {
      max-width: 450px;
      margin: 80px auto;
      padding: 40px;
      border-radius: 12px;
      background: #ffffff;
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .brand {
      font-weight: 800;
      font-size: 26px;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 20px;
    }

    .skip-link {
      text-decoration: none;
      font-size: 14px;
    }

    .btn-dark {
      border-radius: 8px;
      font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="referral-card">

    <div class="brand">SHOEZO 👟</div>

    <h4 class="text-center mb-3">Got a Referral Code?</h4>
    <p class="text-center text-muted">
      Enter a referral code to unlock special rewards 🎁
    </p>

    <form action="/apply-referral-google" method="POST">

      <div class="mb-3">
        <input 
          type="text" 
          name="referralCode" 
          class="form-control text-uppercase"
          placeholder="Enter Referral Code"
        >
      </div>

      <div class="d-grid mb-3">
        <button type="submit" class="btn btn-dark">
          Apply Code
        </button>
      </div>

    </form>

    <div class="text-center">
      <a href="/" class="skip-link text-muted">
        Skip for now →
      </a>
    </div>

  </div>

</body>
</html>