            <script>
              document.addEventListener("DOMContentLoaded", () => {


                const thumbs = document.querySelectorAll('#thumbs img');
                const mainImage = document.getElementById('mainImage');

                thumbs.forEach(t => {
                  t.addEventListener('click', () => {
                    const full = t.dataset.full;
                    if (!full) return;
                    mainImage.src = full;
                    thumbs.forEach(x => x.classList.remove('active-border'));
                    t.classList.add('active-border');
                  });
                });


                const zoomContainer = document.querySelector('.zoom-container');
                const zoomImage = document.querySelector('.zoom-image');

                if (zoomContainer && zoomImage) {
                  zoomContainer.addEventListener('mousemove', (e) => {
                    const rect = zoomContainer.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    zoomImage.style.transformOrigin = `${x}px ${y}px`;
                  });

                  zoomContainer.addEventListener('mouseenter', () => {
                    zoomContainer.classList.add('zoomed');
                  });

                  zoomContainer.addEventListener('mouseleave', () => {
                    zoomContainer.classList.remove('zoomed');
                  });
                }

                const variantButtons = document.querySelectorAll(".variant-btn");
                const variantInput = document.getElementById("selectedVariant");
                const offerPriceEl = document.getElementById("productPrice");
                const originalPriceEl = document.getElementById("originalPrice");

                if (!variantInput || variantButtons.length === 0) {
                  console.error("Variant input or buttons missing");
                  return;
                }


                const firstBtn = variantButtons[0];
                variantInput.value = JSON.stringify({
                  size: String(firstBtn.dataset.size)
                });

                if (offerPriceEl) {
                  offerPriceEl.innerText = "₹" + Number(firstBtn.dataset.price).toLocaleString();
                }
                if (originalPriceEl) {
                  originalPriceEl.innerText = "MRP ₹" + Number(firstBtn.dataset.original).toLocaleString();
                }

                console.log("DEFAULT SIZE:", firstBtn.dataset.size);


                variantButtons.forEach(btn => {
                  btn.addEventListener("click", () => {
                    const stock = Number(btn.dataset.stock);
                    const stockStatus = document.getElementById("stockStatus");
                    const addToCartBtn = document.getElementById("addToCartBtn");
                    const buyNowBtn = document.getElementById("buyNowBtn");


                    variantButtons.forEach(b => {
                      const bStock = Number(b.dataset.stock);
                      b.classList.remove("bg-black", "text-white", "border-black");
                      b.classList.add("bg-white", "text-gray-800", "border-gray-300");
                      if (bStock <= 0) b.classList.add("bg-gray-100", "opacity-40");
                    });

                    btn.classList.add("bg-black", "text-white", "border-black");
                    if (stock <= 0) btn.classList.remove("bg-white", "bg-gray-100");


                    variantInput.value = JSON.stringify({
                      size: String(btn.dataset.size)
                    });


                    if (offerPriceEl) {
                      offerPriceEl.innerText = "₹" + Number(btn.dataset.price).toLocaleString();
                    }
                    if (originalPriceEl) {
                      originalPriceEl.innerText = "MRP ₹" + Number(btn.dataset.original).toLocaleString();
                    }


                    if (stock <= 0) {
                      stockStatus.classList.remove("hidden");
                      addToCartBtn.disabled = true;
                      buyNowBtn.disabled = true;
                    } else {
                      stockStatus.classList.add("hidden");
                      addToCartBtn.disabled = false;
                      buyNowBtn.disabled = false;
                    }

                    console.log("SELECTED SIZE:", btn.dataset.size, "STOCK:", stock);
                  });
                });


                const initialStock = Number(firstBtn.dataset.stock);
                if (initialStock <= 0) {
                  document.getElementById("stockStatus").classList.remove("hidden");
                  document.getElementById("addToCartBtn").disabled = true;
                  document.getElementById("buyNowBtn").disabled = true;
                }


                const wishlistBtn = document.querySelector(".wishlist-btn");
                if (wishlistBtn) {
                  wishlistBtn.addEventListener("click", async () => {
                    const productId = wishlistBtn.dataset.id;
                    const icon = wishlistBtn.querySelector("svg");
                    
                    try {
                      const response = await fetch("/wishlist/add", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify({ productId })
                      });
                      const data = await response.json();
                      if (data.success) {
                        if (data.status === "added") {
                          wishlistBtn.classList.remove("text-gray-400");
                          wishlistBtn.classList.add("text-red-500");
                          icon.setAttribute("fill", "currentColor");
                          icon.classList.add("heart-pulse");
                          setTimeout(() => icon.classList.remove("heart-pulse"), 400);

                          const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true,
                          });
                          Toast.fire({
                            icon: 'success',
                            title: 'Added to wishlist'
                          });
                        } else {
                          wishlistBtn.classList.remove("text-red-500");
                          wishlistBtn.classList.add("text-gray-400");
                          icon.setAttribute("fill", "none");
                          
                          const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true,
                          });
                          Toast.fire({
                            icon: 'info',
                            title: 'Removed from wishlist'
                          });
                        }

                        if (typeof loadWishlistCount === 'function') {
                          loadWishlistCount();
                        }
                      } else {
                        if (data.message === "Login required") {
                          Swal.fire({
                            title: "Login Required",
                            text: "Please login to add products to wishlist",
                            icon: "info",
                            showCancelButton: true,
                            confirmButtonText: "Login",
                            confirmButtonColor: "#000"
                          }).then((result) => {
                            if (result.isConfirmed) {
                              window.location.href = "/login";
                            }
                          });
                        } else {
                          Swal.fire("Error", data.message || "Could not update wishlist", "error");
                        }
                      }
                    } catch (error) {
                      console.error("Wishlist Error:", error);
                    }
                  });
                }

                const addToCartForm = document.getElementById("addToCartForm");
                if (addToCartForm) {
                  addToCartForm.addEventListener("submit", async (e) => {
                    e.preventDefault();

                    const variantData = variantInput.value;
                    const productId = "<%= product._id %>";

                    try {
                      const response = await fetch(`/cart/${productId}`, {
                        method: "POST",
                        headers: {
                          "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ variant: variantData })
                      });

                      const data = await response.json();

                      if (data.success) {
                        Swal.fire({
                          title: "Success!",
                          text: data.message,
                          icon: "success",
                          showCancelButton: true,
                          confirmButtonText: "Go to Cart",
                          cancelButtonText: "Continue Shopping",
                          confirmButtonColor: "#000",
                          cancelButtonColor: "#6c757d"
                        }).then((result) => {
                          if (result.isConfirmed) {
                            window.location.href = "/cart";
                          } else {
                            
                            const cartCountBadge = document.getElementById("cartCount");
                            if (cartCountBadge) {
                              cartCountBadge.innerText = parseInt(cartCountBadge.innerText) + 1;
                            }
                          }
                        });
                      } else {
                        if (data.loginRedirect) {
                          Swal.fire({
                            title: "Login Required",
                            text: data.message,
                            icon: "info",
                            showCancelButton: true,
                            confirmButtonText: "Login",
                            confirmButtonColor: "#000"
                          }).then((result) => {
                            if (result.isConfirmed) {
                              window.location.href = "/login";
                            }
                          });
                        } else {
                          Swal.fire({
                            title: "Oops!",
                            text: data.message,
                            icon: "error",
                            confirmButtonColor: "#000"
                          });
                        }
                      }
                    } catch (error) {
                      console.error("Error adding to cart:", error);
                      Swal.fire({
                        title: "Error",
                        text: "Something went wrong. Please try again.",
                        icon: "error"
                      });
                    }
                  });
                }

            
                const starBtns = document.querySelectorAll(".star-btn");
                const ratingInput = document.getElementById("ratingValue");

                starBtns.forEach(btn => {
                  btn.addEventListener("click", () => {
                    const val = btn.dataset.value;
                    ratingInput.value = val;
                    
                  
                    starBtns.forEach(s => {
                      if (parseInt(s.dataset.value) <= parseInt(val)) {
                        s.classList.remove("text-gray-300");
                        s.classList.add("text-yellow-400");
                      } else {
                        s.classList.remove("text-yellow-400");
                        s.classList.add("text-gray-300");
                      }
                    });
                  });
                });

                const reviewForm = document.getElementById("reviewForm");
                if (reviewForm) {
                  reviewForm.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    
                    const rating = ratingInput.value;
                    const comment = document.getElementById("reviewText").value.trim();
                    const productId = "<%= product._id %>";

                    if (rating === "0") {
                      return Swal.fire("Required", "Please select a star rating", "warning");
                    }
                    if (!comment) {
                      return Swal.fire("Required", "Please write a comment", "warning");
                    }

                    try {
                      const response = await fetch("/add-review", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ productId, rating, comment })
                      });

                      const data = await response.json();

                      if (data.success) {
                        Swal.fire({
                          title: "Success!",
                          text: data.message,
                          icon: "success",
                          confirmButtonColor: "#000"
                        }).then(() => {
                          window.location.reload();
                        });
                      } else {
                        if (data.loginRedirect) {
                          Swal.fire({
                            title: "Login Required",
                            text: data.message,
                            icon: "info",
                            showCancelButton: true,
                            confirmButtonText: "Login",
                            confirmButtonColor: "#000"
                          }).then((result) => {
                            if (result.isConfirmed) {
                              window.location.href = "/login";
                            }
                          });
                        } else {
                          Swal.fire("Error", data.message, "error");
                        }
                      }
                    } catch (error) {
                      console.error("Review Error:", error);
                      Swal.fire("Error", "Something went wrong. Please try again.", "error");
                    }
                  });
                }
              });
            </script>

      </body>