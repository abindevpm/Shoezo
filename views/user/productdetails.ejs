<% /* ---------- FALLBACK DEMO DATA (Used if server-side data is missing) ---------- */ const demoProduct={ _id: 'demo1'
  , name: "Nike Cryptokick" , model: "Custom Shoes" , price: 7799, oldPrice: 9999, offerPrice: 5459, discount: 30,
  description: "Nike Cryptokick — sleek, comfy and futuristic. Example description for demo." , images:
  [ '/images/nike-cryptokick-main.png' , '/images/nike-cryptokick-thumb1.png' , '/images/nike-cryptokick-thumb2.png' ],
  variants: [ { color: "#000000" , size: 6 }, { color: "#f97316" , size: 7 }, { color: "#ef4444" , size: 8 } ], rating:
  4.8, reviewCount: 45, fitRating: 4.5 }; const demoReviews=[ { name: "Abinav George" , date: "3 days ago" , rating:
  4.7, comment: "Great product, very good quality." , verified: true }, { name: "Sulochana Sowmaya" , date: "2 days ago"
  , rating: 4.9, comment: "Awesome product!" , verified: true } ]; const demoSimilar=[ { _id: 's1' , name: "JORDAN 7D" ,
  price: 4999, oldPrice: 9999, discount: 50, image: 'https://placehold.co/400x300/18181b/fff?text=JORDAN+7D' , rating:
  4.9 }, { _id: 's2' , name: "NIKE SPARX" , price: 4999, oldPrice: 9999, discount: 50,
  image: 'https://placehold.co/400x300/60a5fa/fff?text=NIKE+SPARX' , rating: 4.5 } ]; const currentProduct=(typeof
  product !=='undefined' && product) ? product : demoProduct; const currentReviews=(typeof reviews !=='undefined' &&
  reviews) ? reviews : demoReviews; const currentSimilarProducts=(typeof similarProducts !=='undefined' &&
  similarProducts) ? similarProducts : demoSimilar; /* Helpers */
    function generateStars(rating, size='w-4 h-4' ) {
      const full=Math.floor(rating || 0);
      const half=(rating || 0) - full>= 0.5;
      let html = '';
      for (let i = 0; i < 5; i++) {
        const color=(i < full) ? 'text-yellow-400' : (i===full && half) ? 'text-yellow-400 opacity-50' : 'text-gray-300' ;
        html +=`<svg class="${size} ${color} inline-block fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>`;
      }
      return html;
    }

    function ratingPercentFor(star) {
      const map = { 5: 70, 4: 15, 3: 10, 2: 3, 1: 2 };
      return map[star] || 0;
    }

    function fitPercent(rating) {
      const r = (typeof rating === 'number') ? rating : (currentProduct.fitRating || 0);
      return Math.round((r / 5) * 100);
    }

    function imgUrl(img) {
      if (!img) return '/images/placeholder-500.png';
      if (typeof img !== 'string') return '/images/placeholder-500.png';
      if (img.startsWith('http') || img.startsWith('/')) return img;
      return '/uploads/product-images/' + img;
    }
