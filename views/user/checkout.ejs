<script>
  const changeBtn = document.getElementById("changeAddressBtn");
  const addressList = document.getElementById("addressList");
  const selectedBox = document.getElementById("selectedAddressBox");
  const selectedInput = document.getElementById("addressIdInput");


  if (changeBtn) {
    changeBtn.onclick = () => {
      addressList.style.display = "block";
    };
  }

  const showAddBtn = document.getElementById("showAddAddressFormBtn");
  const newAddressForm = document.getElementById("newAddressForm");

  if (showAddBtn) {
    showAddBtn.onclick = () => {
      newAddressForm.style.display = newAddressForm.style.display === "none" ? "block" : "none";
      showAddBtn.innerText = newAddressForm.style.display === "none" ? "+ Add New Address" : "Cancel";
    }
  }

  async function saveNewAddress() {
    const data = {
      fullName: document.getElementById("newFullName").value,
      phone: document.getElementById("newPhone").value,
      addressLine: document.getElementById("newAddressLine").value,
      city: document.getElementById("newCity").value,
      state: document.getElementById("newState").value,
      pincode: document.getElementById("newPincode").value
    };

    if (Object.values(data).some(val => !val.trim())) {
      return Swal.fire("Required", "Please fill all fields", "warning");
    }

    try {
      const response = await fetch("/checkout/add-address", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      const result = await response.json();
      if (result.success) {
        const addr = result.address;


        const option = document.createElement("label");
        option.className = "address-option";
        option.innerHTML = `
          <input type="radio" name="addressRadio" value="${addr._id}" checked>
          <div class="address-text">
            <strong>${addr.fullName} <br> ${addr.addressLine}<br> ${addr.pincode}</strong>
            <p>${addr.city}, ${addr.state}</p>
            <p>Mobile: +91 ${addr.phone}</p>
          </div>
        `;
        document.getElementById("addressList").insertBefore(option, document.getElementById("confirmAddressBtn").previousSibling.previousSibling);

        // Update selection UI
        selectedBox.querySelector(".addr-name strong").innerHTML = `${addr.fullName},<br>${addr.addressLine},<br>${addr.pincode}`;
        selectedBox.querySelector(".addr-desc").innerText = `${addr.city}, ${addr.state}`;
        selectedBox.querySelector(".addr-phone").innerText = `Mobile: +91 ${addr.phone}`;
        selectedInput.value = addr._id;

        Swal.fire("Success", "Address added and selected!", "success");
        addressList.style.display = "none";
        newAddressForm.style.display = "none";
        showAddBtn.innerText = "+ Add New Address";
      } else {
        Swal.fire("Error", result.message, "error");
      }
    } catch (error) {
      Swal.fire("Error", "Something went wrong", "error");
    }
  }

  const saveBtn = document.getElementById("saveNewAddressBtn");
  if (saveBtn) saveBtn.onclick = saveNewAddress;

  const confirmBtn = document.getElementById("confirmAddressBtn");
  if (confirmBtn) {
    confirmBtn.onclick = () => {
      const selected = document.querySelector("input[name='addressRadio']:checked");
      if (!selected) return;

      const label = selected.closest(".address-option");
      const nameLine = label.querySelector("strong").innerText;
      const desc = label.querySelector("p").innerText;
      const phone = label.querySelectorAll("p")[1].innerText;

      selectedBox.querySelector(".addr-name strong").innerText = nameLine;
      selectedBox.querySelector(".addr-desc").innerText = desc;
      selectedBox.querySelector(".addr-phone").innerText = phone;

      selectedInput.value = selected.value;
      addressList.style.display = "none";
    };
  }


  document.getElementById("rzp-button").addEventListener("click", async function (e) {
    const addressId = document.getElementById("addressIdInput") ? document.getElementById("addressIdInput").value : "";

    if (!addressId) {
      return Swal.fire({
        icon: "warning",
        title: "Select Address",
        text: "Please select delivery address"
      });
    }

    try {
      const response = await fetch("/create-order", {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ addressId })
      });

      const data = await response.json();

      if (!data.success) {
        return Swal.fire("Error", data.message || "Unable to create order", "error");
      }

      const dbOrderId = data.dbOrderId;

      const options = {
        key: "<%= razorpayKey %>",
        amount: data.order.amount,
        currency: "INR",
        name: "Shoezo",
        description: "Order Payment",
        order_id: data.order.id,

        handler: async function (response) {
          const verifyRes = await fetch("/verify-payment", {
            method: "POST",
            credentials: "include",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature
            })
          });

          const verifyData = await verifyRes.json();

          if (verifyData.success) {
            window.location.href = "/order-success";
          } else {
            // Mark payment as failed in DB if verification fails
            await fetch("/mark-order-failed", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ dbOrderId })
            });
            window.location.href = `/order-failure?orderId=${dbOrderId}`;
          }
        },
        modal: {
          ondismiss: async function () {
            // Mark payment as failed when user closes the modal
            await fetch("/mark-order-failed", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ dbOrderId })
            });
            window.location.href = `/order-failure?orderId=${dbOrderId}`;
          }
        }
      };

      const rzp = new Razorpay(options);

      rzp.on("payment.failed", async function (response) {
        // Mark payment as failed when payment fails
        await fetch("/mark-order-failed", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ dbOrderId })
        });
        window.location.href = `/order-failure?orderId=${dbOrderId}`;
      });

      rzp.open();

    } catch (error) {
      console.error("Payment Error:", error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  });


  const paymentOptions = document.querySelectorAll('input[name="paymentMethod"]');
  const placeOrderBtn = document.querySelector('.btn-place-order');
  const rzpBtn = document.getElementById('rzp-button');
  const walletPayBtn = document.getElementById('wallet-pay-btn');

  function toggleButtons() {
    const selected = document.querySelector('input[name="paymentMethod"]:checked').value;


    placeOrderBtn.style.display = 'none';
    if (rzpBtn) rzpBtn.style.display = 'none';
    if (walletPayBtn) walletPayBtn.style.display = 'none';

    if (selected === 'COD') {
      placeOrderBtn.style.display = 'block';
    } else if (selected === 'ONLINE') {
      if (rzpBtn) rzpBtn.style.display = 'block';
    } else if (selected === 'WALLET') {
      if (walletPayBtn) walletPayBtn.style.display = 'block';
    }
  }

  paymentOptions.forEach(opt => opt.addEventListener('change', toggleButtons));


  toggleButtons();


  async function submitOrder() {
    const addressId = document.getElementById("addressIdInput")?.value;
    const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked')?.value;

    if (!addressId) {
      return Swal.fire("Warning", "Please select a delivery address", "warning");
    }

    try {
      const response = await fetch("/place-order", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ addressId, paymentMethod })
      });

      const result = await response.json();
      if (result.success) {
        window.location.href = "/order-success";
      } else {
        Swal.fire("Error", result.message || "Something went wrong", "error");
      }
    } catch (error) {
      console.error("Order error:", error);
      Swal.fire("Error", "Internal Server Error", "error");
    }
  }

  const orderForm = document.querySelector('form[action="/place-order"]');
  if (orderForm) {
    orderForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      await submitOrder();
    });
  }


  if (walletPayBtn) {
    walletPayBtn.addEventListener('click', () => {
      Swal.fire({
        title: 'Confirm Payment',
        text: "Are you sure you want to pay using your wallet?",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#000',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, Pay Now'
      }).then(async (result) => {
        if (result.isConfirmed) {
          await submitOrder();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');
    if (error) {
      Swal.fire({
        icon: 'error',
        title: 'Order Failed',
        text: error,
        confirmButtonColor: '#000'
      });
    }
  });



  async function applyCoupon() {

    const code = document.getElementById("couponCode").value.trim();

    if (!code) {
      return Swal.fire("Error", "Please enter coupon code", "warning");
    }

    try {
      const response = await fetch("/apply-coupon", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ code })
      });

      const data = await response.json();

      if (data.success) {
        document.getElementById("couponDiscountRow").style.display = "flex";
        document.getElementById("couponDiscountAmount").innerText = data.discount;
        document.getElementById("finalTotal").innerText = data.finalTotal;

        document.getElementById("couponMessage").innerText =
          "Coupon Applied Successfully ✅";

      } else {
        document.getElementById("couponMessage").innerText = data.message;
      }

    } catch (error) {
      console.error(error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  }

  async function removeCoupon() {
    try {
      const res = await fetch("/remove-coupon", { method: "POST" });
      const data = await res.json();

      if (data.success) {
        // hide coupon discount row
        document.getElementById("couponDiscountRow").style.display = "none";
        document.getElementById("couponDiscountAmount").innerText = "0";

        // reset total back to original discounted price
        document.getElementById("finalTotal").innerText = data.totalPrice;

        // clear coupon input and message
        document.getElementById("couponCode").value = "";
        document.getElementById("couponMessage").innerText = "Coupon removed.";
      }
    } catch (err) {
      console.error("Remove coupon error:", err);
    }
  }





  async function loadCoupons() {
    try {
      // Use final cart total (after offer discounts) to filter eligible coupons
      const cartTotal = parseFloat(document.getElementById("finalTotal").innerText) || <%= totalPrice %>;
      const response = await fetch(`/available-coupons?subtotal=${cartTotal}`);
      const data = await response.json();

      if (!data.success) return;

      const container = document.getElementById("couponList");
      container.innerHTML = "";

      if (data.coupons.length === 0) {
        container.innerHTML = '<p style="font-size: 14px; color: #666; padding: 10px;">No coupons available at this time.</p>';
        return;
      }

      data.coupons.forEach(coupon => {
        const expiryDate = new Date(coupon.expiryDate).toLocaleDateString('en-GB', {
          day: 'numeric',
          month: 'short',
          year: 'numeric'
        });

        const div = document.createElement("div");
        div.className = "coupon-card";

        div.innerHTML = `
          <div class="coupon-header-row">
            <strong>${coupon.code}</strong>
            <span class="coupon-offer">
              ${coupon.discountType === "percentage"
            ? coupon.discountValue + "% OFF"
            : "₹" + coupon.discountValue + " OFF"}
            </span>
          </div>
          <div class="coupon-details">
            Min Purchase: ₹${coupon.minPurchase}<br>
            <span class="coupon-expiry">Expires: ${expiryDate}</span>
          </div>
          <button onclick="autoApply('${coupon.code}')">
            Apply Coupon
          </button>
        `;

        container.appendChild(div);
      });

    } catch (error) {
      console.log(error);
    }
  }

  function autoApply(code) {
    document.getElementById("couponCode").value = code;
    applyCoupon();
  }

  document.addEventListener("DOMContentLoaded", loadCoupons);




</script>