    gap: 14px;
    align-items: center;
  }

  .payment-icon {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  .payment-title {
    font-weight: 600;
    font-size: 15px;
  }

  .payment-desc {
    font-size: 13px;
    color: #666;
  }

  .wallet-balance {
    color: #16a34a;
    font-weight: 600;
  }

  #rzp-button,
