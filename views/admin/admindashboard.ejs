<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SHOEZO - Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    
    /* Smooth hover animation for sidebar */
    .sidebar-link {
      transition: all 0.3 s ease;
      position: relative;
      overflow: hidden;
    }
    
.sidebar-link:hover {
  background-color: #1f2937 ;
  transform: translateX(4 px);
}
    
    .sidebar-link:active {
      transform: scale(0.98);
    }

    /* Optional: Add subtle focus ring for accessibility */
    .page-btn:focus {
      outline: 2 px solid #3b82f6;
      outline-offset: 2 px;
    }
  </style>
</head>
<body class="bg-gray-100">

<div class="flex h-screen">

  <!-- Enhanced Sidebar -->
  <div class="w-64 bg-white shadow-xl flex flex-col">
    <!-- SHOEZO Title -->
    <div class="relative">
      <div class="p-6 text-3xl font-bold text-gray-900">SHOEZO</div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gray-200"></div>
    </div>
    
    <nav class="flex-1 px-4 py-6 space-y-2">
      <!-- Dashboard (Active Style) -->
      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-white">
        <i class="fas fa-tachometer-alt"></i>
        <span class="font-medium">Dashboard</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-users"></i>
        <span class="font-medium">Customers</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-box"></i>
        <span class="font-medium">Products</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-shopping-cart"></i>
        <span class="font-medium">Orders</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-tag"></i>
        <span class="font-medium">Coupon Management</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-chart-line"></i>
        <span class="font-medium">Sales Report</span>
      </a>

      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-list"></i>
        <span class="font-medium">Category</span>
      </a>

      <!-- Offers - Now Active (No Blue Line) -->
      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-white">
        <i class="fas fa-percent"></i>
        <span class="font-medium">Offers</span>
      </a>
    </nav>

    <!-- Bottom Section -->
    <div class="border-t border-gray-200 p-4 space-y-2">
      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-cog"></i>
        <span class="font-medium">Settings</span>
      </a>
      <a href="#" class="sidebar-link flex items-center space-x-4 px-5 py-3 rounded-xl bg-gray-800 text-gray-300 hover:text-white">
        <i class="fas fa-sign-out-alt"></i>
        <span class="font-medium">Logout</span>
      </a>
    </div>
  </div>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto">
    <header class="bg-white shadow-sm px-8 py-4 flex justify-between items-center">
      <div></div>
      <div class="flex items-center space-x-4">
        <i class="far fa-bell text-gray-600 text-xl"></i>
        <i class="far fa-sun text-gray-600 text-xl"></i>
        <span class="font-medium text-gray-800">ABHEEH</span>
      </div>
    </header>

    <div class="p-8">

      <!-- Stats Cards -->
      <div class="grid grid-cols-4 gap-6 mb-8">
        <div class="bg-red-100 rounded-2xl p-6 text-center">
          <div class="text-gray-600 text-sm">Total Sales</div>
          <div class="text-2xl font-bold text-gray-800">₹ 5,55,000</div>
        </div>
        <div class="bg-green-100 rounded-2xl p-6 text-center">
          <div class="text-gray-600 text-sm">Visitors</div>
          <div class="text-2xl font-bold text-gray-800">2,500</div>
        </div>
        <div class="bg-blue-100 rounded-2xl p-6 text-center">
          <div class="text-gray-600 text-sm">Total Orders</div>
          <div class="text-2xl font-bold text-gray-800">1,500</div>
        </div>
        <div class="bg-yellow-100 rounded-2xl p-6 text-center">
          <div class="text-gray-600 text-sm">Users</div>
          <div class="text-2xl font-bold text-gray-800">1,013</div>
        </div>
      </div>

      <!-- Revenue Chart -->
      <div class="bg-white rounded-xl shadow-sm p-6 mb-8">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h2 class="text-xl font-semibold">Total Revenue</h2>
            <p class="text-3xl font-bold">₹50,23,780 
              <span class="text-green-600 text-sm font-medium ml-2">Up 5% than last month</span>
            </p>
          </div>
          <div class="flex items-center space-x-4 text-sm">
            <span class="flex items-center"><div class="w-3 h-3 bg-blue-600 rounded-full mr-2"></div>Profit</span>
            <span class="flex items-center"><div class="w-3 h-3 bg-gray-300 rounded-full mr-2"></div>Loss</span>
          </div>
        </div>

        <div class="relative h-64 flex items-end justify-between px-4">
          <div class="absolute bottom-0 left-0 right-0 border-t border-gray-300"></div>
          <div class="absolute left-0 top-0 bottom-0 border-l border-gray-300"></div>
          
          <div class="flex w-full justify-between">
            <% const heights = [90, 85, 80, 75, 70, 45, 80, 70, 85]; %>
            <% const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep']; %>
            <% for(let i = 0; i < 9; i++) { %>
              <div class="flex flex-col items-center flex-1">
                <div class="w-12 <%= i%2===0 ? 'bg-gray-900' : 'bg-gray-300' %> rounded-t transition-all" style="height: <%= heights[i] %>px;"></div>
                <span class="text-xs text-gray-600 mt-2"><%= months[i] %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Latest Orders Table -->
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-xl font-semibold mb-4">Latest Orders</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="text-gray-500 border-b">
                <th class="pb-3">Order ID</th>
                <th class="pb-3">Product</th>
                <th class="pb-3">Date</th>
                <th class="pb-3">Customer</th>
                <th class="pb-3">Total</th>
                <th class="pb-3">Payment</th>
                <th class="pb-3">Status</th>
              </tr>
            </thead>
            <tbody class="text-gray-700">
              <tr class="border-b hover:bg-gray-50">
                <td class="py-4">#302012</td>
                <td class="py-4 flex items-center space-x-3">
                  <div class="w-10 h-10 bg-orange-100 rounded flex items-center justify-center text-xs font-medium">NC</div>
                  <div>Nike CITY <br><span class="text-xs text-gray-500">+3 Products</span></div>
                </td>
                <td>29 Dec 2022</td>
                <td>jayadev</td>
                <td>₹59,000</td>
                <td>24 Jun 2023</td>
                <td><span class="bg-pink-100 text-pink-700 px-3 py-1 rounded-full text-xs font-medium">Processing</span></td>
              </tr>
              <tr class="border-b hover:bg-gray-50">
                <td class="py-4">#302013</td>
                <td class="py-4 flex items-center space-x-3">
                  <div class="w-10 h-10 bg-red-100 rounded flex items-center justify-center text-xs font-medium">NZ</div>
                  <div>Nike Zoom <br><span class="text-xs text-gray-500">+2 Products</span></div>
                </td>
                <td>28 Dec 2022</td>
                <td>rahul_k</td>
                <td>₹78,000</td>
                <td>23 Jun 2023</td>
                <td><span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-medium">Delivered</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="py-4">#302014</td>
                <td class="py-4 flex items-center space-x-3">
                  <div class="w-10 h-10 bg-gray-200 rounded flex items-center justify-center text-xs font-medium">JR</div>
                  <div>Jordan Retro 3 <br><span class="text-xs text-gray-500">+1 Product</span></div>
                </td>
                <td>27 Dec 2022</td>
                <td>priya_s</td>
                <td>₹1,20,000</td>
                <td>22 Jun 2023</td>
                <td><span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-medium">Pending</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Modern Pagination with Arrows -->
        <div class="mt-8 flex flex-col items-center">
          <div class="text-sm text-gray-600 mb-4">Showing 1 to 3 of 100 entries</div>
          
          <div class="flex items-center space-x-3">
            <!-- Previous Button -->
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 flex items-center justify-center transition page-btn" aria-label="Previous page">
              <i class="fas fa-chevron-left text-gray-700"></i>
            </button>

            <!-- Page Numbers -->
            <button class="w-10 h-10 rounded-lg bg-blue-600 text-white font-medium page-btn">1</button>
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium page-btn transition">2</button>
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium page-btn transition">3</button>
            <span class="text-gray-500 px-2">...</span>
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium page-btn transition">23</button>
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium page-btn transition">24</button>

            <!-- Next Button -->
            <button class="w-10 h-10 rounded-lg bg-gray-200 hover:bg-gray-300 flex items-center justify-center transition page-btn" aria-label="Next page">
              <i class="fas fa-chevron-right text-gray-700"></i>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

</body>
</html>