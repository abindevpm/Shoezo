<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">







<header class="navbar-custom">
  <div class="container-xl">
    <div class="navbar-inner">

      <div class="nav-left">
        <!-- LOGO -->
        <a href="/" class="logo">SHOEZO</a>
      </div>

      <!-- NAV -->
      <nav class="nav-links nav-center">
        <a href="/">Home</a>
        <a href="/productlist">Shop</a>
        <a href="/orders">Orders</a>
      </nav>

      <div class="nav-right">
        <!-- ACTION ICONS -->

    <a href="/wishlist" class="nav-icon">
  <i class="fa-solid fa-heart"></i>
  <span id="wishlist-count" class="nav-badge">0</span>
</a>

           



          <a href="/cart" class="icon-link" title="Cart">
            <i class="fa fa-shopping-cart"></i>
            <span id="cartCount" class="cart-badge">
              <%= cartCount || 0 %>
            </span>
          </a>


        <!-- SEARCH -->
        <form action="/productlist" method="GET" class="search-box d-none d-lg-block">
          <input type="text" name="search" placeholder="Search"
            value="<%= typeof search !== 'undefined' ? search : '' %>">
          <button type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </form>

        <!-- USER -->
        <div class="user-area">
          <% if (locals.user && locals.user.name) { %>
            <% const initial=locals.user.name.charAt(0).toUpperCase(); %>

              <div class="dropdown">
                <button class="user-btn" data-bs-toggle="dropdown">
                  <!-- <div class="avatar">
                    <%= initial %>
                  </div> -->

                  <img 
                    src="<%= locals.user.profileImage && locals.user.profileImage !== '' ? locals.user.profileImage : '/images/default-avatar.jpg' %>" 
                    class="avatar-img"
                    alt="profile">


                  <span>
                    
                    <%= locals.user.name %>
                  </span>
                  <i class="fa-solid fa-chevron-down"></i>
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="/profile">My Profile</a></li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
                </ul>
              </div>

              <% } else { %>
                <a href="/login">Login</a>
                <a href="/signup">Signup</a>
                <% } %>
        </div>
      </div>
    </div>
  </div>
</header>



<style>
  /* ===== EXACT TAILWIND NAVBAR LOOK ===== */



  .avatar-img {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  object-fit: cover;
}



  .navbar-custom {
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid #e5e7eb;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    gap: 40px;
  }

  /* LOGO */
  .logo {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #000;
    text-decoration: none;
  }

  /* NAV LINKS */
  .nav-links {
    display: flex;
    gap: 32px;
    font-weight: 500;
  }

  .nav-links a {
    text-decoration: none;
    color: #4b5563;
  }

  .nav-links a:hover {
    color: #000;
  }

  /* SEARCH */
  .search-box {
    position: relative;
  }

  .search-box input {
    width: 256px;
    padding: 8px 40px 8px 16px;
    border-radius: 9999px;
    border: 1px solid #d1d5db;
    font-size: 14px;
    outline: none;
  }

  .search-box input:focus {
    border-color: #374151;
  }

  .search-box button {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #6b7280;
  }

  /* USER AREA */
  .user-area {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .user-area a {
    text-decoration: none;
    font-weight: 500;
    color: #4b5563;
  }

  .user-area a:hover {
    color: #000;
  }

  /* ICON LINKS */
  .icon-link {
    font-size: 20px;
    color: #4b5563;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    position: relative;
    width: 24px;
    height: 24px;
  }

  .icon-link:hover {
    color: #000;
    transform: translateY(-1px);
  }

  .action-icons {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .nav-left,
  .nav-right {
    flex: 1 1 0;
    display: flex;
    align-items: center;
  }

  .nav-right {
    justify-content: flex-end;
    gap: 32px;
    min-width: fit-content;
  }

  .nav-center {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
  }


  /* USER BUTTON */
  .user-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    font-weight: 600;
  }

  /* AVATAR */
  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }




  .cart-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    background: #ef4444;
    color: white;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 9999px;
    min-width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #fff;
  }


  .nav-icon {
  position: relative;
  display: inline-block;
  font-size: 22px;
  color: #555;
}

/* icon */
.nav-icon i {
  font-size: 22px;
}

/* 🔴 perfect badge */
.nav-badge {
  position: absolute;
  top: -5px;
  right: -6px;
  background: #e74c3c;
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  border-radius: 50%;
  padding: 2px 5px;
  min-width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}


</style>




<script>
  document.addEventListener("DOMContentLoaded", () => {
    loadWishlistCount();
  });

  async function loadWishlistCount() {
    try {
      const res = await fetch("/wishlist/count");
      const data = await res.json();

      const badge = document.getElementById("wishlist-count");

      if (!badge) return;

      if (data.count > 0) {
        badge.style.display = "flex";
        badge.innerText = data.count;
      } else {
        badge.style.display = "none";
      }

    } catch (err) {
      console.log(err);
    }
  }

  
  async function addToWishlist(productId) {
    try {
      const res = await fetch("/wishlist/add", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ productId })
      });

      const data = await res.json();

      if (data.success) {
        loadWishlistCount(); 
      }

    } catch (err) {
      console.log(err);
    }
  }
</script>